---
/**
 * Services.astro — Featured services grid with elegant cards.
 * "Reservar" adds to cart AND opens the cart drawer.
 */
import { servicesData } from '../data/translations.js';

const featured = servicesData.filter(s => s.featured);
---

<section class="services section-padding" id="servicios">
  <div class="container">
    <div class="section-header reveal">
      <h2 data-i18n-es="Nuestros Servicios" data-i18n-en="Our Services">Nuestros Servicios</h2>
      <p data-i18n-es="Tratamientos diseñados para renovar tu cuerpo y espíritu" data-i18n-en="Treatments designed to renew your body and spirit">
        Tratamientos diseñados para renovar tu cuerpo y espíritu
      </p>
    </div>

    <div class="services__grid">
      {featured.map((service, idx) => (
        <article class="services__card reveal" style={`animation-delay: ${idx * 0.12}s`}>
          <!-- Image -->
          <div class="services__img-wrap">
            <img
              src={service.image}
              alt={service.name.es}
              class="services__img"
              loading="lazy"
              width="600"
              height="400"
            />
            <!-- Price badge -->
            <div class="services__price">${service.price} <span>MXN</span></div>
            <!-- Hover overlay -->
            <div class="services__overlay">
              <button
                class="services__reserve-btn"
                data-service-id={service.id}
                data-service-name-es={service.name.es}
                data-service-name-en={service.name.en}
                data-service-price={service.price}
                data-service-image={service.image}
                data-i18n-es="Agregar y Reservar"
                data-i18n-en="Add & Reserve"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                Agregar y Reservar
              </button>
            </div>
          </div>

          <!-- Body -->
          <div class="services__body">
            <div class="services__cat-tag">
              {service.category === 'massage' && (
                <span data-i18n-es="Masajes" data-i18n-en="Massage">Masajes</span>
              )}
              {service.category === 'facial' && (
                <span data-i18n-es="Facial" data-i18n-en="Facial">Facial</span>
              )}
              {service.category === 'body' && (
                <span data-i18n-es="Corporal" data-i18n-en="Body">Corporal</span>
              )}
              {service.category === 'beauty' && (
                <span data-i18n-es="Belleza" data-i18n-en="Beauty">Belleza</span>
              )}
            </div>
            <h3
              class="services__title"
              data-i18n-es={service.name.es}
              data-i18n-en={service.name.en}
            >
              {service.name.es}
            </h3>
            <p
              class="services__desc"
              data-i18n-es={service.description.es}
              data-i18n-en={service.description.en}
            >
              {service.description.es}
            </p>
            <!-- Mobile-friendly button (always visible on mobile) -->
            <button
              class="services__mobile-btn"
              data-service-id={service.id}
              data-service-name-es={service.name.es}
              data-service-name-en={service.name.en}
              data-service-price={service.price}
              data-service-image={service.image}
              data-i18n-es="Agregar y Reservar"
              data-i18n-en="Add & Reserve"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 01-8 0"/>
              </svg>
              Agregar y Reservar
            </button>
          </div>
        </article>
      ))}
    </div>

    <div class="services__more reveal">
      <button class="services__menu-btn" id="openMenuBtn" data-i18n-es="Ver Menú Completo" data-i18n-en="View Full Menu">
        Ver Menú Completo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--cream-soft);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    max-width: 1060px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .services__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Card */
  .services__card {
    background: var(--white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(74, 21, 58, 0.07);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .services__card:hover {
    box-shadow: 0 10px 40px rgba(74, 21, 58, 0.16);
    transform: translateY(-6px);
  }

  /* Image */
  .services__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .services__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }

  .services__card:hover .services__img {
    transform: scale(1.08);
  }

  /* Price badge */
  .services__price {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: rgba(74, 21, 58, 0.88);
    backdrop-filter: blur(8px);
    color: var(--gold-warm);
    padding: 5px 12px;
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    z-index: 2;
  }

  .services__price span {
    font-size: 0.65rem;
    opacity: 0.7;
    font-weight: 500;
  }

  /* Hover overlay with button */
  .services__overlay {
    position: absolute;
    inset: 0;
    background: rgba(74, 21, 58, 0.72);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
    z-index: 3;
  }

  @media (min-width: 960px) {
    .services__card:hover .services__overlay {
      opacity: 1;
      pointer-events: all;
    }
  }

  .services__reserve-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.5rem;
    background: var(--gold-warm);
    color: var(--purple-deep);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: all var(--transition-fast);
    transform: translateY(8px);
    transition: all 0.3s ease;
  }

  .services__card:hover .services__reserve-btn {
    transform: translateY(0);
  }

  .services__reserve-btn:hover {
    background: var(--gold-light);
    transform: scale(1.04) !important;
  }

  /* Body */
  .services__body {
    padding: var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 6px;
  }

  .services__cat-tag {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-warm);
  }

  .services__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--purple-deep);
    font-family: var(--font-heading);
    line-height: 1.3;
    margin-top: 2px;
  }

  .services__desc {
    font-size: 0.82rem;
    color: var(--gray-700);
    line-height: 1.55;
    flex: 1;
    margin-top: 2px;
  }

  /* Mobile button (shows below the card body, hidden on desktop hover) */
  .services__mobile-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.55rem 1.1rem;
    margin-top: var(--space-sm);
    background: transparent;
    color: var(--purple-medium);
    border: 1.5px solid var(--purple-medium);
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--transition-fast);
    align-self: flex-start;
  }

  .services__mobile-btn:hover {
    background: var(--purple-deep);
    border-color: var(--purple-deep);
    color: var(--cream-soft);
  }

  @media (min-width: 960px) {
    /* On desktop, the overlay button handles it — hide the mobile one */
    .services__mobile-btn {
      display: none;
    }
  }

  /* View full menu button */
  .services__more {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  .services__menu-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.9rem 2.4rem;
    background: transparent;
    color: var(--purple-deep);
    border: 1.5px solid var(--purple-deep);
    border-radius: 4px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .services__menu-btn svg {
    transition: transform var(--transition-fast);
  }

  .services__menu-btn:hover {
    background: var(--purple-deep);
    color: var(--cream-soft);
  }

  .services__menu-btn:hover svg {
    transform: translateX(4px);
  }
</style>

<script is:inline>
  (function() {
    function addAndOpenCart(btn) {
      var lang = window.SPA_LANG || 'es';
      window.addToCart({
        id: btn.dataset.serviceId,
        name: { es: btn.dataset.serviceNameEs, en: btn.dataset.serviceNameEn },
        price: parseInt(btn.dataset.servicePrice),
        image: btn.dataset.serviceImage,
      });

      /* Open cart drawer */
      var drawer = document.getElementById('cartDrawer');
      var overlay = document.getElementById('cartOverlay');
      if (drawer) {
        drawer.classList.add('open');
        overlay.classList.add('open');
        document.body.classList.add('no-scroll');
        window.dispatchEvent(new CustomEvent('cartOpened'));
      }

      /* Visual feedback on the button */
      var origHTML = btn.innerHTML;
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ' + (lang === 'es' ? '¡Agregado!' : 'Added!');
      btn.style.pointerEvents = 'none';
      setTimeout(function() {
        btn.innerHTML = origHTML;
        btn.style.pointerEvents = '';
      }, 1800);
    }

    /* Both the overlay button and mobile button */
    document.querySelectorAll('.services__reserve-btn, .services__mobile-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        addAndOpenCart(btn);
      });
    });

    /* Open full menu modal */
    var menuBtn = document.getElementById('openMenuBtn');
    if (menuBtn) {
      menuBtn.addEventListener('click', function() {
        var modal = document.getElementById('servicesModal');
        if (modal) {
          modal.classList.add('open');
          document.body.classList.add('no-scroll');
        }
      });
    }
  })();
</script>
