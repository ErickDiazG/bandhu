---
/**
 * Contact.astro — "Te Estamos Esperando" section with spa image,
 * contact info, hours, social links, and WhatsApp CTA.
 */
---

<section class="contact section-padding" id="contacto">
  <div class="container">
    <div class="section-header reveal">
      <h2 data-i18n-es="Te Estamos Esperando" data-i18n-en="We're Waiting for You">Te Estamos Esperando</h2>
      <p data-i18n-es="Visítanos y vive la experiencia Bandhú" data-i18n-en="Visit us and live the Bandhú experience">
        Visítanos y vive la experiencia Bandhú
      </p>
    </div>

    <div class="contact__content reveal">
      <!-- Image Side -->
      <div class="contact__image-wrap">
        <img
          src="/images/te-esperamos.webp"
          alt="Bandhú Spa Interior"
          class="contact__image"
          loading="lazy"
          width="600"
          height="800"
        />
        <div class="contact__image-accent"></div>
      </div>

      <!-- Info Side -->
      <div class="contact__info">
        <!-- Phone -->
        <div class="contact__item">
          <div class="contact__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div>
            <h4 data-i18n-es="Teléfono" data-i18n-en="Phone">Teléfono</h4>
            <a href="tel:+524445451940" class="contact__link">+52 444 545 1940</a>
          </div>
        </div>

        <!-- Address -->
        <div class="contact__item">
          <div class="contact__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h4 data-i18n-es="Ubicación" data-i18n-en="Location">Ubicación</h4>
            <p class="contact__text">Cto. San Miguel 139, Bosque de Lindavista ll, 78421 Pozos, S.L.P.</p>
          </div>
        </div>

        <!-- Hours -->
        <div class="contact__item">
          <div class="contact__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h4 data-i18n-es="Horario" data-i18n-en="Hours">Horario</h4>
            <div class="contact__schedule">
              <p data-i18n-es="Lunes a Viernes: 10am - 2pm y 4pm - 8pm" data-i18n-en="Monday to Friday: 10am - 2pm & 4pm - 8pm">Lunes a Viernes: 10am - 2pm y 4pm - 8pm</p>
              <p data-i18n-es="Sábados: 10am - 5:30pm" data-i18n-en="Saturdays: 10am - 5:30pm">Sábados: 10am - 5:30pm</p>
              <p class="contact__closed" data-i18n-es="Domingos: Cerrado" data-i18n-en="Sundays: Closed">Domingos: Cerrado</p>
            </div>
          </div>
        </div>

        <!-- Social Media -->
        <div class="contact__social">
          <h4 data-i18n-es="Síguenos" data-i18n-en="Follow Us">Síguenos</h4>
          <div class="contact__social-links">
            <a href="https://www.facebook.com/BandhuSpa/" target="_blank" rel="noopener noreferrer" class="contact__social-btn" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/spabandhu" target="_blank" rel="noopener noreferrer" class="contact__social-btn" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/524445451940?text=Hola%2C%20me%20gustaría%20agendar%20una%20cita%20en%20Bandhú%20Spa"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary contact__whatsapp"
          data-i18n-es="Escríbenos por WhatsApp"
          data-i18n-en="Message Us on WhatsApp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--white);
  }

  .contact__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .contact__content {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }

  .contact__image-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .contact__image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  @media (min-width: 768px) {
    .contact__image {
      height: 500px;
    }
  }

  .contact__image-accent {
    position: absolute;
    bottom: -10px;
    right: -10px;
    width: 120px;
    height: 120px;
    border: 3px solid var(--gold-warm);
    border-radius: var(--radius-lg);
    z-index: -1;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact__item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .contact__icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--purple-deep), var(--purple-medium));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cream-soft);
    flex-shrink: 0;
  }

  .contact__item h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold-warm);
    margin-bottom: 4px;
    font-family: var(--font-body);
    font-weight: 700;
  }

  .contact__link {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--purple-deep);
    transition: color var(--transition-fast);
  }

  .contact__link:hover {
    color: var(--gold-warm);
  }

  .contact__text {
    font-size: 0.92rem;
    color: var(--gray-700);
  }

  .contact__schedule p {
    font-size: 0.9rem;
    color: var(--gray-700);
    margin-bottom: 2px;
  }

  .contact__closed {
    color: var(--gray-700) !important;
    font-weight: 600;
    font-style: italic;
  }

  .contact__social h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold-warm);
    margin-bottom: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 700;
  }

  .contact__social-links {
    display: flex;
    gap: var(--space-sm);
  }

  .contact__social-btn {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--purple-deep);
    color: var(--cream-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
  }

  .contact__social-btn:hover {
    background: var(--gold-warm);
    color: var(--purple-deep);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .contact__whatsapp {
    gap: var(--space-sm);
    align-self: flex-start;
  }
</style>
