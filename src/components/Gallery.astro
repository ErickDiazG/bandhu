---
/**
 * Gallery.astro — Infinite auto-scrolling carousel with Unsplash spa images.
 * Pure CSS animation, no JS library needed. Pauses on hover.
 */
import { galleryImages } from '../data/translations.js';
---

<section class="gallery section-padding" id="galeria">
  <div class="container">
    <div class="section-header reveal">
      <h2 data-i18n-es="Nuestra Galería" data-i18n-en="Our Gallery">Nuestra Galería</h2>
      <p data-i18n-es="Hemos diseñado estos espacios para ti" data-i18n-en="We have designed these spaces for you">
        Hemos diseñado estos espacios para ti
      </p>
    </div>
  </div>

  <div class="gallery__track-wrapper reveal">
    <div class="gallery__track">
      {/* First set */}
      {galleryImages.map((img) => (
        <div class="gallery__item">
          <img src={img.src} alt={img.alt} loading="lazy" width="400" height="560" />
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {galleryImages.map((img) => (
        <div class="gallery__item">
          <img src={img.src} alt={img.alt} loading="lazy" width="400" height="560" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--purple-deep);
    overflow: hidden;
  }

  .gallery .section-header h2 {
    color: var(--cream-soft);
  }

  .gallery .section-header p {
    color: rgba(250, 245, 237, 0.65);
  }

  .gallery__track-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .gallery__track {
    display: flex;
    gap: var(--space-md);
    width: max-content;
    animation: infiniteScroll 40s linear infinite;
  }


  .gallery__item {
    flex-shrink: 0;
    width: 280px;
    height: 400px;
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery__item:hover img {
    transform: scale(1.1);
  }

  .gallery__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(74, 21, 58, 0.4), transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery__item:hover::after {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .gallery__item {
      width: 400px;
      height: 560px;
    }
  }
</style>
